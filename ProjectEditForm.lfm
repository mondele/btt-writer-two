object ProjectEditWindow: TProjectEditWindow
  Left = 100
  Height = 700
  Top = 50
  Width = 1100
  Caption = 'Project Editor'
  Color = clWhite
  OnClose = FormClose
  OnCreate = FormCreate
  Position = poScreenCenter
  LCLVersion = '4.0.0.0'
  object TopPanel: TPanel
    Left = 0
    Height = 45
    Top = 0
    Width = 1100
    Align = alTop
    BevelOuter = bvNone
    Color = 4281410
    ParentColor = False
    TabOrder = 0
    object btnBack: TButton
      Left = 8
      Height = 30
      Top = 8
      Width = 70
      Caption = '<- Back'
      Font.Color = clWhite
      OnClick = btnBackClick
      TabOrder = 0
    end
    object lblProjectTitle: TLabel
      Left = 90
      Height = 20
      Top = 12
      Width = 400
      Caption = 'Project'
      Font.Color = clWhite
      Font.Height = -15
      Font.Style = [fsBold]
      ParentColor = False
      ParentFont = False
    end
    object lblChapterNav: TLabel
      Left = 750
      Height = 20
      Top = 12
      Width = 80
      Caption = 'Chapter'
      Font.Color = clWhite
      Font.Height = -14
      ParentColor = False
      ParentFont = False
      Alignment = taRightJustify
      Anchors = [akTop, akRight]
    end
    object btnPrevChapter: TButton
      Left = 840
      Height = 30
      Top = 8
      Width = 30
      Caption = '<'
      OnClick = btnPrevChapterClick
      TabOrder = 1
      Anchors = [akTop, akRight]
    end
    object lblChapterNum: TLabel
      Left = 880
      Height = 20
      Top = 12
      Width = 40
      Caption = '01'
      Font.Color = clWhite
      Font.Height = -15
      Font.Style = [fsBold]
      ParentColor = False
      ParentFont = False
      Alignment = taCenter
      Anchors = [akTop, akRight]
    end
    object btnNextChapter: TButton
      Left = 930
      Height = 30
      Top = 8
      Width = 30
      Caption = '>'
      OnClick = btnNextChapterClick
      TabOrder = 2
      Anchors = [akTop, akRight]
    end
  end
  object StatusPanel: TPanel
    Left = 0
    Height = 25
    Top = 675
    Width = 1100
    Align = alBottom
    BevelOuter = bvNone
    Color = 4281410
    ParentColor = False
    TabOrder = 1
    object lblStatus: TLabel
      Left = 16
      Height = 15
      Top = 5
      Width = 600
      Caption = 'Ready'
      Font.Color = clWhite
      Font.Height = -12
      ParentFont = False
    end
  end
  object SplitPanel: TPanel
    Left = 0
    Height = 630
    Top = 45
    Width = 1100
    Align = alClient
    BevelOuter = bvNone
    TabOrder = 2
    object Splitter1: TSplitter
      Left = 360
      Height = 630
      Top = 0
      Width = 5
    end
    object Splitter2: TSplitter
      Left = 775
      Height = 630
      Top = 0
      Width = 5
      Align = alRight
    end
    object SourcePanel: TPanel
      Left = 0
      Height = 630
      Top = 0
      Width = 360
      Align = alLeft
      BevelOuter = bvNone
      Color = 15263976
      ParentColor = False
      TabOrder = 0
      object lblSourceHeader: TLabel
        Left = 0
        Height = 26
        Top = 0
        Width = 360
        Caption = 'Source Text'
        Align = alTop
        Color = clWhite
        Font.Height = -13
        Font.Style = [fsBold]
        ParentColor = False
        ParentFont = False
        Layout = tlCenter
      end
      object SourceLangHeader: TLabel
        Left = 0
        Height = 22
        Top = 26
        Width = 360
        Caption = 'Plateau Malagasy ULB'
        Align = alTop
        Color = 15921906
        Font.Color = 7303023
        Font.Height = -12
        Font.Style = [fsBold]
        ParentColor = False
        ParentFont = False
        Layout = tlCenter
      end
      object SourceScrollBox: TScrollBox
        Left = 0
        Height = 582
        Top = 48
        Width = 360
        Align = alClient
        BorderStyle = bsNone
        TabOrder = 0
      end
    end
    object TransPanel: TPanel
      Left = 455
      Height = 630
      Top = 0
      Width = 320
      Align = alClient
      BevelOuter = bvNone
      Color = 15395562
      ParentColor = False
      TabOrder = 1
      object lblTransHeader: TLabel
        Left = 0
        Height = 26
        Top = 0
        Width = 320
        Caption = 'Translation'
        Align = alTop
        Color = clWhite
        Font.Height = -13
        Font.Style = [fsBold]
        ParentColor = False
        ParentFont = False
        Layout = tlCenter
      end
      object TransScrollBox: TScrollBox
        Left = 0
        Height = 604
        Top = 26
        Width = 320
        Align = alClient
        BorderStyle = bsNone
        TabOrder = 0
      end
    end
    object ResourcePanel: TPanel
      Left = 780
      Height = 630
      Top = 0
      Width = 320
      Align = alRight
      BevelOuter = bvNone
      Color = 15263976
      ParentColor = False
      TabOrder = 2
      object ResourceTabsPanel: TPanel
        Left = 0
        Height = 32
        Top = 0
        Width = 320
        Align = alTop
        BevelOuter = bvNone
        Color = clWhite
        ParentColor = False
        TabOrder = 0
        object btnTabNotes: TButton
          Left = 8
          Height = 24
          Top = 4
          Width = 84
          Caption = 'Notes'
          Enabled = False
          TabOrder = 0
        end
        object btnTabWords: TButton
          Left = 96
          Height = 24
          Top = 4
          Width = 84
          Caption = 'Words'
          Enabled = False
          TabOrder = 1
        end
        object btnTabQuestions: TButton
          Left = 184
          Height = 24
          Top = 4
          Width = 98
          Caption = 'Questions'
          Enabled = False
          TabOrder = 2
        end
      end
      object ResourceMemo: TMemo
        Left = 0
        Height = 598
        Top = 32
        Width = 320
        Align = alClient
        BorderStyle = bsNone
        Color = clWhite
        Font.Color = 4492305
        Font.Height = -15
        ParentFont = False
        ReadOnly = True
        ScrollBars = ssAutoVertical
        TabOrder = 1
        Lines.Strings = (
          'Context resources will appear here.'
        )
      end
    end
  end
  object AutoSaveTimer: TTimer
    Interval = 300000
    OnTimer = AutoSaveTimerFire
    Enabled = False
  end
end
