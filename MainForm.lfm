object MainWindow: TMainWindow
  Left = 200
  Height = 620
  Top = 100
  Width = 980
  Caption = 'BTT-Writer'
  Color = clWhite
  OnCreate = FormCreate
  OnResize = FormResize
  Position = poScreenCenter
  LCLVersion = '4.0.0.0'
  object HeaderPanel: TPanel
    Left = 0
    Height = 40
    Top = 0
    Width = 980
    Align = alTop
    BevelOuter = bvNone
    Color = 26258
    ParentColor = False
    TabOrder = 0
    object lblAppName: TLabel
      Left = 16
      Height = 24
      Top = 8
      Width = 90
      Caption = 'BTT Writer'
      Font.Color = clWhite
      Font.Height = -28
