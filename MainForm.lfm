      ParentFont = False
    end
    object lblCurrentUser: TLabel
      Left = 620
      Height = 20
      Top = 10
      Width = 220
      Caption = 'Current User: Raphael'
      Font.Color = clWhite
      Font.Height = -21
      ParentColor = False
      ParentFont = False
      Alignment = taRightJustify
      Anchors = [akTop, akRight]
    end
    object btnLogout: TLabel
      Left = 848
      Height = 20
      Top = 10
      Width = 100
